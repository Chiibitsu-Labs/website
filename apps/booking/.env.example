# ─── Google Calendar ───────────────────────────────────────────────────────────
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Obtain via the one-time OAuth setup (see README)
GOOGLE_REFRESH_TOKEN=
# Use "primary" for your main calendar, or paste a specific calendar ID
GOOGLE_CALENDAR_ID=primary

# ─── Email (Resend) ─────────────────────────────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY=
# Must be a verified domain in Resend (e.g. booking@chiibitsu.com)
EMAIL_FROM=booking@chiibitsu.com
# Your email — receives a notification for every new booking
ADMIN_EMAIL=chii@chiibitsu.com

# ─── Admin Panel ────────────────────────────────────────────────────────────────
# Password to access /admin — choose something strong
ADMIN_PASSWORD=

# ─── Secrets ────────────────────────────────────────────────────────────────────
# Signs booking approval + reschedule links. Generate with: openssl rand -base64 32
# Falls back to ADMIN_PASSWORD if unset, but set it — otherwise changing
# ADMIN_PASSWORD invalidates every approval/reschedule link already sent out.
BOOKING_TOKEN_SECRET=
# From Tally: form → Integrations → Webhooks → Signing secret.
# If unset, the payment webhook accepts unsigned requests (not recommended).
TALLY_SIGNING_SECRET=

# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://booking.chiibitsu.com
# Timezone for displaying times (IANA format)
NEXT_PUBLIC_TIMEZONE=Asia/Manila
