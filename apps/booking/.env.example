# ─── Google Calendar ───────────────────────────────────────────────────────────
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Obtain via the one-time OAuth setup (see README)
GOOGLE_REFRESH_TOKEN=
# Use "primary" for your main calendar, or paste a specific calendar ID
GOOGLE_CALENDAR_ID=primary

# ─── Email (Resend) ─────────────────────────────────────────────────────────────
# Get your API key from https://resend.com
RESEND_API_KEY=
# Must be a verified domain in Resend (e.g. booking@chiibitsu.com)
EMAIL_FROM=booking@chiibitsu.com
# Your email — receives a notification for every new booking
ADMIN_EMAIL=chii@chiibitsu.com


# ─── Supabase (booking projects admin) ────────────────────────────────────────
# Vercel's Supabase integration may provide NEXT_PUBLIC_SUPABASE_URL and
# NEXT_PUBLIC_SUPABASE_ANON_KEY automatically. For the admin project editor,
# SUPABASE_SERVICE_ROLE_KEY is preferred, but SUPABASE_ANON_KEY also works if
# your booking_projects table allows inserts/updates.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ─── Admin Panel ────────────────────────────────────────────────────────────────
# Password to access /admin — choose something strong
ADMIN_PASSWORD=

# ─── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://booking.chiibitsu.com
# Timezone for displaying times (IANA format)
NEXT_PUBLIC_TIMEZONE=Asia/Manila
